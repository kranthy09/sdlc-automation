# Copy to .env and fill in values before running locally.
# Never commit .env to git.

# LLM
ANTHROPIC_API_KEY=sk-ant-...

# Storage
POSTGRES_URL=postgresql+asyncpg://platform:dev_password@localhost:5432/ai_platform
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# Optional: LangSmith tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=enterprise-ai-platform

# Optional: override log level (default: INFO)
LOG_LEVEL=INFO
