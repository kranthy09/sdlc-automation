# Virtual env and uv cache (8.8GB — Docker reinstalls via uv sync --frozen)
.venv/
.uv/

# Type/lint/test caches (350MB+)
.mypy_cache/
.dmypy.json
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
.tox/

# Git history
.git/
.github/

# UI build artifacts (213MB — not needed in API container)
ui/node_modules/
ui/dist/
ui/.vite/

# Python bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/

# Secrets and local config
.env
.env.local
*.pem
*.key

# Logs
*.log
logs/

# Large knowledge base binaries
knowledge_bases/**/*.jsonl.gz
knowledge_bases/**/*.index

# Docker and infra volumes
infra/docker/volumes/

# Docs and tests (not needed in running container)
docs/
tests/

# IDE and OS
.vscode/
.idea/
.DS_Store
Thumbs.db
.ipynb_checkpoints/
